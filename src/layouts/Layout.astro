---
interface Props {
  title?: string;
}
const { title = 'Honey the Hamster Fitness Tracker' } = Astro.props;
const siteUrl = 'https://honey.parente.dev';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#62543e" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="A memorial for Honey the Hamster, who ran over 1,886 miles in her exercise wheel."
    />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/honey.jpg`} />
    <meta property="og:image:width" content="400" />
    <meta property="og:image:height" content="400" />
  </head>
  <body>
    <div class="container">
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  html,
  body {
    padding: 0;
    margin: 0;
    font-family: 'Roboto', sans-serif;
    color: #211c20;
    background-color: #62543e;
    background-image:
      repeating-linear-gradient(
        120deg,
        rgba(255, 255, 255, 0.1),
        rgba(255, 255, 255, 0.1) 1px,
        transparent 1px,
        transparent 60px
      ),
      repeating-linear-gradient(
        60deg,
        rgba(255, 255, 255, 0.1),
        rgba(255, 255, 255, 0.1) 1px,
        transparent 1px,
        transparent 60px
      ),
      linear-gradient(
        60deg,
        rgba(0, 0, 0, 0.1) 25%,
        transparent 25%,
        transparent 75%,
        rgba(0, 0, 0, 0.1) 75%,
        rgba(0, 0, 0, 0.1)
      ),
      linear-gradient(
        120deg,
        rgba(0, 0, 0, 0.1) 25%,
        transparent 25%,
        transparent 75%,
        rgba(0, 0, 0, 0.1) 75%,
        rgba(0, 0, 0, 0.1)
      );
    background-size: 70px 120px;
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: #8c7744;
    text-decoration: none;
  }

  h1 {
    font-size: 1.25rem;
    font-weight: normal;
    clear: both;
  }

  h2 {
    font-size: 1.1rem;
    font-weight: normal;
    clear: both;
  }

  ul {
    padding: 0;
  }

  ul li {
    list-style-position: inside;
  }
</style>

<style>
  .container {
    max-width: 42rem;
    padding: 1rem 1.5em;
    margin: 0 auto;
    background-color: #f8f6f2;
    box-shadow: 0px 0px 10px #ddd7c7;
  }

  .container :global(p) {
    text-align: justify;
    line-height: 1.65rem;
    margin-bottom: 2.5rem;
  }

  .container :global(li) {
    text-align: justify;
    line-height: 1.65rem;
  }

  .container :global(section) {
    margin-bottom: 3.5rem;
    clear: both;
  }

  .container :global(hr) {
    border: 0 solid white;
    height: 1px;
    width: 66%;
    background-color: #ddd7c7;
    margin-bottom: 3.5rem;
  }
</style>
